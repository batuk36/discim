rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Kullanıcı profil fotoğrafları
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024;
    }

    // Klinik logoları
    match /clinic_logos/{clinicId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024;
    }

    // Klinik fotoğrafları
    match /clinic_photos/{clinicId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Dişçi profil fotoğrafları
    match /dentist_photos/{clinicId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
