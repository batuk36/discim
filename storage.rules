rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profil fotoğrafları — sadece kendi fotoğrafını yükleyebilir
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Klinik logoları — sadece klinik sahibi yükleyebilir
    match /clinic_logos/{clinicId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && firestore.get(/databases/(default)/documents/clinics/$(clinicId)).data.ownerId == request.auth.uid;
    }

    // Klinik fotoğrafları — sadece klinik sahibi yükleyebilir
    match /clinic_photos/{clinicId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && firestore.get(/databases/(default)/documents/clinics/$(clinicId)).data.ownerId == request.auth.uid;
    }
  }
}
